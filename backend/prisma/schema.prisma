generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Review {
  id         String   @id @default(cuid())
  repoName   String
  prNumber   Int
  prTitle    String
  prAuthor   String
  verdict    String
  summary    String
  issueCount Int
  createdAt  DateTime @default(now())
  issues     Issue[]
}

model Issue {
  id       String @id @default(cuid())
  reviewId String
  file     String
  line     Int
  severity String
  message  String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model User {
  id             String   @id @default(cuid())
  clerkId        String   @unique
  githubUsername String   @unique
  alertEmail     String
  createdAt      DateTime @default(now())
}
